{
  "manifest_version": 3,
  "name": "Yargıtay Karar Asistanı",
  "version": "1.0.0",
  "description": "Yargıtay kararlarını toplu toplayın; istatistik görün, filtreleyin ve PDF, Word veya Excel (CSV) olarak dışa aktarın.",
  "permissions": ["storage", "alarms", "downloads", "notifications", "tabs", "scripting"],
  "host_permissions": ["*://karararama.yargitay.gov.tr/*"],
  "icons": {
    "16": "icons/extension-icon16.png",
    "48": "icons/extension-icon48.png",
    "128": "icons/extension-icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Yargıtay Karar Asistanı",
    "default_icon": {
      "16": "icons/extension-icon16.png",
      "48": "icons/extension-icon48.png",
      "128": "icons/extension-icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://karararama.yargitay.gov.tr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
